{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "references": [{ "path": "../blueapi" }],
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/testUtils.tsx"
  ]
}
