{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "eslint.config.*", ".eslintrc.*"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": ["src/**", "vitest.config.*"]
    },
    "coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts"],
      "outputs": ["coverage/**"]
    }
  }
}
